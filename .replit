entrypoint = "src/app/page.tsx"
modules = ["nodejs-22"]
run = "npm run dev -- --hostname 0.0.0.0"

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "cloudrun"
build = "npm run build"
run = "npm run start -- --hostname 0.0.0.0 --port ${PORT:-3000}"

[env]
NEXT_TELEMETRY_DISABLED = "1"

[[ports]]
localPort = 3000
externalPort = 80

[agent]
expertMode = true
